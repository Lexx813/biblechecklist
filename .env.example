# JW Study — environment variables.
# Copy to .env.local for development. Never commit .env.local.
# Production values live in the Vercel project (Settings → Environment Variables).

# ── Supabase (required) ──────────────────────────────────────────────
# Public — exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://yudyhigvqaodnoqwwtns.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# URL to invoke Edge Functions from the client.
NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=https://yudyhigvqaodnoqwwtns.supabase.co/functions/v1
# Server-only — bypasses RLS. Must NOT be NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── App / SEO ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://jwstudy.org
# Donation flow target. Stripe Checkout link or jw.org donate page.
NEXT_PUBLIC_DONATE_URL=

# ── Push notifications ───────────────────────────────────────────────
# VAPID public key (browser-side push subscription).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Observability ────────────────────────────────────────────────────
# Sentry browser DSN. Optional in dev.
NEXT_PUBLIC_SENTRY_DSN=

# ── AI Companion (server-only) ───────────────────────────────────────
# Anthropic API key for AIStudyBubble tool calls.
ANTHROPIC_API_KEY=

# ── Rate limiting (Upstash Redis, server-only) ───────────────────────
# Used by /api routes via rateLimit() helper. Postgres triggers cover
# direct supabase-js writes; this covers server route cap.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Some helpers expect KV_*-prefixed aliases (Vercel KV legacy).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Email ────────────────────────────────────────────────────────────
# HMAC secret for signed email-unsubscribe links.
UNSUB_SECRET=

# ── Build / dev ──────────────────────────────────────────────────────
# Set to "true" to run @next/bundle-analyzer during build.
# ANALYZE=true
